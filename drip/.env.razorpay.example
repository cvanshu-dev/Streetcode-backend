# Razorpay Configuration Example
# Copy this to .env.local and fill in your actual values

# === DATABASE ===
DATABASE_URL=postgres://user:password@localhost:5432/medusa_development
REDIS_URL=redis://localhost:6379

# === MEDUSA SERVER ===
MEDUSA_ADMIN_ONBOARDING_TYPE=skip
JWT_SECRET=test_secret_change_me_in_production
COOKIE_SECRET=test_secret_change_me_in_production

# === CORS & Security ===
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:3000

# === RAZORPAY - REQUIRED ===
# Get these from https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_SECRET=xxxxxxxxxxxxxxxx

# === RAZORPAY - OPTIONAL ===
# For multi-account setup
# RAZORPAY_ACCOUNT=acc_xxxxxxxxxxxxx
# or for testing
RAZORPAY_TEST_ACCOUNT=

# === RAZORPAY - WEBHOOKS ===
# Get this from https://dashboard.razorpay.com/app/settings/webhooks
# Set webhook URL to: https://yoursite.com/store/razorpay/webhooks
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_TEST_WEBHOOK_SECRET=

# === NODE ENVIRONMENT ===
NODE_ENV=development
# NODE_ENV=production

# === WORKER MODE ===
# Options: "shared" (default), "worker", "server"
MEDUSA_WORKER_MODE=shared

# === MEDUSA DEBUG ===
# DEBUG=medusa:*
# DEBUG=medusa:payment

# === FILE STORAGE (if using S3) ===
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# === MAIL SERVICE (if configured) ===
# SENDGRID_API_KEY=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# === STRIPE (if using as additional payment provider) ===
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
